# Copy this file ONCE to ~/.xyric/framework.env (outside any repo) and fill
# in real keys. Never commit a filled copy. chmod 600 recommended.
# These are personal, cross-project credentials -- same value regardless of
# which repo you're working in. Per-project/service-specific keys (email,
# maps, payments, etc.) belong in the project's own .env, not here -- see
# SKILL-BANK/README.md "Credentials" section.

# Z.ai GLM Coding Plan
ZAI_API_KEY=
# ZAI_MODEL=glm-5.1            # optional override for direct worker pings

# DeepSeek direct API
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro       # optional override for direct worker pings

# Direct Anthropic API (optional -- most sessions use Codex or `claude` login instead)
# ANTHROPIC_API_KEY=

# Supermemory (optional; only needed if a future Supermemory skill/tool is enabled)
# SUPERMEMORY_CC_API_KEY=
