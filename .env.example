# Copy to .env.local for local dev, or set these in Railway → Variables.

# Database. The Prisma schema uses PostgreSQL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Secret used to sign auth JWTs. Use at least 32 random characters.
JWT_SECRET="replace-with-at-least-32-random-characters"
