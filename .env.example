# Copy to .env.local for local dev, or set these in Railway → Variables.

# Database. Local dev uses SQLite. On Railway, attach a Postgres service
# and set this to the provided connection string (and update prisma schema
# datasource provider to "postgresql").
DATABASE_URL="file:./dev.db"

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Secret used to sign auth JWTs. Use a long random string.
JWT_SECRET=
