datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  barCouncilId String?
  phone        String?
  city         String?
  language     String   @default("en")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  documents      Document[]
  chatSessions   ChatSession[]
  matters        Matter[]
  diaryEntries   DiaryEntry[]
  savedJudgments SavedJudgment[]
  legalCases     LegalCase[]
}

model Document {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  title            String
  category         String
  subType          String
  language         String   @default("en")
  status           String   @default("draft")
  formData         String
  generatedContent String
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, category])
  @@index([userId, createdAt])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime    @default(now())
}

model Matter {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  caseNo      String?
  court       String
  caseType    String
  status      String   @default("active")
  role        String
  clientName  String
  clientCnic  String?
  clientPhone String?
  opponentName String?
  judgeName   String?
  dateFiled   DateTime?
  nextHearing DateTime?
  notes       String?
  documentIds String   @default("[]")
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hearings MatterHearing[]

  @@index([userId, status])
  @@index([userId, nextHearing])
}

model MatterHearing {
  id        String   @id @default(cuid())
  matterId  String
  matter    Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  date      DateTime
  purpose   String?
  result    String?
  nextDate  DateTime?
  createdAt DateTime @default(now())
}

model DiaryEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  caseNumber  String?
  lastDate    DateTime?
  title       String
  courtName   String
  stage       String
  proceeding  String?
  nextDate    DateTime?
  clientPhone String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, nextDate])
}

model SavedJudgment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  citation    String
  title       String?
  court       String?
  year        String?
  summary     String?
  content     String?
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model LegalCase {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  name            String
  status          String    @default("in-progress")
  courtName       String?
  nextHearingDate DateTime?
  clientName      String?
  clientCnic      String?
  clientPhone     String?
  documentIds     String    @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  hearings CaseHearing[]

  @@index([userId, status])
  @@index([userId, nextHearingDate])
}

model CaseHearing {
  id        String    @id @default(cuid())
  caseId    String
  case      LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  date      DateTime
  purpose   String?
  result    String?
  nextDate  DateTime?
  createdAt DateTime  @default(now())

  @@index([caseId])
}

model LegalAct {
  id           Int            @id
  actName      String         @map("act_name") @db.Text
  actYear      Int?           @map("act_year")
  href         String?        @db.Text
  pdfUrl       String?        @map("pdf_url") @db.Text
  fullText     String?        @map("full_text") @db.Text
  sectionCount Int?           @default(0) @map("section_count")
  status       String?        @default("in-force") @db.Text
  scrapedAt    String?        @map("scraped_at") @db.Text
  province     String?        @default("Federal") @db.Text
  docType      String?        @default("act") @map("doc_type") @db.Text

  sections LegalSection[]

  @@index([province])
  @@index([docType])
  @@map("legal_acts")
}

model LegalSection {
  id        Int      @id
  actId     Int      @map("act_id")
  act       LegalAct @relation(fields: [actId], references: [id], onDelete: Cascade)
  sectionNo String?  @map("section_no") @db.Text
  title     String?  @db.Text
  body      String?  @db.Text

  @@index([actId])
  @@index([sectionNo])
  @@map("legal_sections")
}

model LegalMigrationMeta {
  key       String   @id @db.Text
  value     String   @db.Text
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("legal_migration_meta")
}
